{
  "name": "mnd",
  "version": "0.1.0",
  "description": "Personal CLI for AI-assisted video vlog editing — exports to DaVinci Resolve",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mnd": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "pretest": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --testPathPattern=\"test/(levenshtein|box|projectState|slugify|persistentProcess|router|vault)\\.test\\.ts\"",
    "test:smoke": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit --testPathPattern=\"test/pythonSidecar\\.smoke\\.test\\.ts\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@napi-rs/keyring": "^1.1.5",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "figures": "^6.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "gradient-string": "^3.0.0",
    "gray-matter": "^4.0.3",
    "groq-sdk": "^0.7.0",
    "ink": "^5.0.1",
    "listr2": "^8.2.5",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "simple-git": "^3.27.0",
    "string-width": "^7.2.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "ink-testing-library": "^3.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@clack/prompts$": "<rootDir>/test/__mocks__/@clack/prompts.ts",
      "^gradient-string$": "<rootDir>/test/__mocks__/gradient-string.ts",
      "^ink$": "<rootDir>/test/__mocks__/ink.ts",
      "^string-width$": "<rootDir>/test/__mocks__/string-width.ts",
      "^chalk$": "<rootDir>/test/__mocks__/chalk.ts"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json",
          "useESM": false
        }
      ]
    }
  }
}
